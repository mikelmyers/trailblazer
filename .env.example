# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_DRIVER_STANDARD_PRICE_ID=
STRIPE_DRIVER_PRO_PRICE_ID=
STRIPE_SHIPPER_STARTER_PRICE_ID=
STRIPE_SHIPPER_GROWTH_PRICE_ID=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Primordia / Terra
# Next.js client: set PRIMORDIA_API_URL=mock for TypeScript mocks,
# or http://localhost:8100 to hit the real Terra FastAPI service.
PRIMORDIA_API_URL=mock
PRIMORDIA_API_KEY=

# Terra FastAPI service (primordia/external_api/terra)
TERRA_API_DEV_KEY=some-secret
TERRA_API_AUTH_DISABLED=true
