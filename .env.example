# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_DRIVER_FREE_PRICE_ID=          # Free tier ($0) — optional, used for webhook tier detection
STRIPE_DRIVER_STANDARD_PRICE_ID=      # Standard tier ($49/mo)
STRIPE_DRIVER_PRO_PRICE_ID=           # Pro tier ($99/mo)
STRIPE_SHIPPER_CASUAL_PRICE_ID=       # Shipper Casual tier ($29/mo, 5 jobs)
STRIPE_SHIPPER_STARTER_PRICE_ID=      # Shipper Starter tier
STRIPE_SHIPPER_GROWTH_PRICE_ID=       # Shipper Growth tier

# Stripe Connect — required for driver payouts
# Enable Connect in Stripe Dashboard → Connect → Get started
# Webhook must listen for `account.updated` events

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Primordia / Terra
# Next.js client: set PRIMORDIA_API_URL=mock for TypeScript mocks,
# or http://localhost:8100 to hit the real Terra FastAPI service.
PRIMORDIA_API_URL=mock
PRIMORDIA_API_KEY=

# Terra FastAPI service (primordia/external_api/terra)
TERRA_API_DEV_KEY=some-secret
TERRA_API_AUTH_DISABLED=true
